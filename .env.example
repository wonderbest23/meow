# Supabase server connection. Never expose the service role key to the browser.
# Use demo-memory only for local UI development. Production requires supabase.
PERSISTENCE_MODE=demo-memory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Keep false during free beta testing. Set true to enable paid manual-transfer orders.
PAYMENTS_ENABLED=false

# Manual bank transfer. The account is only returned after an order is created.
MANUAL_TRANSFER_BANK_NAME=
MANUAL_TRANSFER_ACCOUNT_NUMBER=
MANUAL_TRANSFER_ACCOUNT_HOLDER=

# Optional. Without this key the server uses deterministic, reviewable draft generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol

# Cloudflare for SaaS. Used only on the server to connect customer-owned domains.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_SAAS_API_TOKEN=
CLOUDFLARE_SAAS_CNAME_TARGET=connect.oneulstart.com

# Toss Payments. Reserved for a later card-payment launch; currently unused.
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Korean official-data connectors. Values are never exposed to the browser.
# Work24 career information Open API
WORK24_API_KEY=
# Public Data Portal: Small Enterprise and Market Service store/trade-area API
DATA_GO_KR_API_KEY=
# KOSIS Open API
KOSIS_API_KEY=
# Seoul Open Data Plaza (needed for Seoul trade-area datasets)
SEOUL_OPEN_DATA_API_KEY=
# SGIS population and business census API (service ID / security key)
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=
# VWorld land-use and spatial data API
VWORLD_API_KEY=

# HMAC secret for official evidence returned to the browser and saved again.
# Use a random 32-byte value in production. The server role key is a local fallback.
EVIDENCE_ATTESTATION_SECRET=

# Password for the private 1:1 support / legal console at /admin (min 8 chars).
ADMIN_CHAT_PASSWORD=

# Optional: dedicated password for the deposit-order console at /admin/payments (min 8 chars).
# When set, payment admin requires its own login and support-console operators cannot
# confirm/refund orders. When empty, /admin/payments keeps using ADMIN_CHAT_PASSWORD.
ADMIN_PAYMENTS_PASSWORD=

# Optional: independent secret for signing admin session cookies (random, min 16 chars).
# When empty, session signatures are derived from the admin password (rotating the password
# then also rotates every session). Setting this lets you invalidate all admin sessions
# without changing the password.
ADMIN_SESSION_SECRET=

# Rate-limit backend. Default (empty) uses a fast per-instance in-memory limiter.
# Set to "supabase" to use the strongly-consistent, global counter (migration 0018) instead.
RATE_LIMIT_BACKEND=

# Platform seller and privacy details. These can also be edited at /admin/legal.
PLATFORM_OPERATOR_NAME=
PLATFORM_REPRESENTATIVE_NAME=
PLATFORM_BUSINESS_NUMBER=
PLATFORM_MAIL_ORDER_STATUS=preparing
PLATFORM_MAIL_ORDER_NUMBER=
PLATFORM_MAIL_ORDER_EXEMPTION_REASON=
PLATFORM_INTERNET_DOMAIN=
PLATFORM_HOST_SERVER_LOCATION=
PLATFORM_BUSINESS_ADDRESS=
PLATFORM_SUPPORT_EMAIL=
PLATFORM_SUPPORT_PHONE=
PLATFORM_PRIVACY_OFFICER=
PLATFORM_PRIVACY_EMAIL=
# Confirm Supabase database/auth and Cloudflare hosting/log processing locations.
INFRASTRUCTURE_PROCESSING_COUNTRIES=
# Confirm the processing locations for the actual OpenAI API project before paid launch.
OPENAI_PROCESSING_COUNTRIES=

# Optional independent secret used to bind guest projects to signed-in accounts.
AUTH_PROJECT_SECRET=
