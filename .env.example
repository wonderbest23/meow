# Supabase server connection. Never expose the service role key to the browser.
# Use demo-memory only for local UI development. Production requires supabase.
PERSISTENCE_MODE=demo-memory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Keep false during beta testing. Set true when Toss Payments is ready to launch.
PAYMENTS_ENABLED=false

# Optional. Without this key the server uses deterministic, reviewable draft generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol

# Toss Payments. Used only when PAYMENTS_ENABLED=true.
# General payment webhooks do not have a signature: the server re-queries Toss by paymentKey.
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Korean official-data connectors. Values are never exposed to the browser.
# Work24 career information Open API
WORK24_API_KEY=
# Public Data Portal: Small Enterprise and Market Service store/trade-area API
DATA_GO_KR_API_KEY=
# KOSIS Open API
KOSIS_API_KEY=
# Seoul Open Data Plaza (needed for Seoul trade-area datasets)
SEOUL_OPEN_DATA_API_KEY=
# SGIS population and business census API (service ID / security key)
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=
# VWorld land-use and spatial data API
VWORLD_API_KEY=

# HMAC secret for official evidence returned to the browser and saved again.
# Use a random 32-byte value in production. The server role key is a local fallback.
EVIDENCE_ATTESTATION_SECRET=

# Password for the private 1:1 support inbox at /admin.
ADMIN_CHAT_PASSWORD=

# Platform seller and privacy details. These can also be edited at /admin/legal.
PLATFORM_OPERATOR_NAME=
PLATFORM_REPRESENTATIVE_NAME=
PLATFORM_BUSINESS_NUMBER=
PLATFORM_MAIL_ORDER_NUMBER=
PLATFORM_BUSINESS_ADDRESS=
PLATFORM_SUPPORT_EMAIL=
PLATFORM_SUPPORT_PHONE=
PLATFORM_PRIVACY_OFFICER=
PLATFORM_PRIVACY_EMAIL=
# Confirm Supabase database/auth and Cloudflare hosting/log processing locations.
INFRASTRUCTURE_PROCESSING_COUNTRIES=
# Confirm the processing locations for the actual OpenAI API project before paid launch.
OPENAI_PROCESSING_COUNTRIES=

# Optional independent secret used to bind guest projects to signed-in accounts.
AUTH_PROJECT_SECRET=
