    "test:setup-wizard": "tsx scripts/setup-wizard.test.ts",
    "test:market": "tsx scripts/market-plan.test.ts",
    "test:landing": "tsx scripts/landing-domain.test.ts",
    "test:operations": "tsx scripts/operations-engine.test.ts",
    "test:execution": "tsx scripts/execution-loop.test.ts",
    "test:regional": "tsx scripts/regional-coverage.test.ts",
    "test:quality": "tsx scripts/quality-assurance.test.ts",
    "test:payment": "tsx scripts/payment-security.test.ts",
    "test:ops": "tsx scripts/service-ops.test.ts",
    "test:grants": "tsx scripts/grant-matcher.test.ts",
    "test:trust": "tsx scripts/recommendation-trust.test.ts",
    "test:planning": "tsx scripts/planning-inputs.test.ts",
    "test:career": "tsx scripts/career-connector.test.ts",
    "test:generation": "tsx scripts/stage-generator.test.ts",
    "test:openai": "tsx scripts/openai-session.test.ts",
    "test:missions": "tsx scripts/launch-missions.test.ts",
    "test:support": "tsx scripts/support-chat.test.ts",
    "test:legal": "tsx scripts/platform-legal.test.ts",
    "test:delivery": "node scripts/delivery-demo.test.mjs",
    "test:paid-quality": "tsx scripts/paid-report-quality.test.ts",
    "test:actual-scenario": "node --env-file-if-exists=.env.local --import tsx scripts/run-actual-scenario.ts",
    "test:persistence": "node --env-file-if-exists=.env.local scripts/persistence-smoke.mjs",
    "test:e2e": "node scripts/e2e-scenario.mjs"
