  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@supabase/supabase-js": "^2.110.2",
    "@tosspayments/tosspayments-sdk": "^2.7.1",
    "docx": "^9.7.1",
    "fast-xml-parser": "^5.10.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "marked": "^16.4.2",
    "next": "^16.2.10",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1",
