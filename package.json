    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "puppeteer-core": "^25.3.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.110.0"
  }
}
